# =============================================================================
#  Virtuals EconomyOS — agent identity + signer
#  Source: https://os.virtuals.io/quickstart  (step 2 + step 4)
# =============================================================================
# 1. Go to app.virtuals.io → your agent → grab these:
VIRTUALS_WALLET_ADDRESS=     # 0x... — your agent's smart wallet address
VIRTUALS_BUILDER_CODE=       # bc-... — from the "Retrieve your builder code" panel

# 2. Signer key + entity ID (the EOA authorized to sign on behalf of the wallet):
VIRTUALS_PRIVATE_KEY=        # 0x... — signer EOA private key
VIRTUALS_ENTITY_ID=1         # number — defaults to 1 for the first signer

# =============================================================================
#  PagerDuty
# =============================================================================
PAGERDUTY_TOKEN=             # API key from Account Settings → API Access Keys
PAGERDUTY_USER_EMAIL=        # email on your PagerDuty account (sandbox email)

# =============================================================================
#  Anthropic — Claude is the agent's brain
# =============================================================================
ANTHROPIC_API_KEY=

# =============================================================================
#  Demo recipient — fallback when GitHub username doesn't map to a known wallet
# =============================================================================
DEMO_FALLBACK_RECIPIENT=     # any 0x address that should receive the tip in the demo

# =============================================================================
#  Optional
# =============================================================================
GITHUB_TOKEN=                # raises GitHub rate limit (60/hr → 5000/hr); optional
PORT=3000
