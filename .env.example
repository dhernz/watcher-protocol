# PagerDuty
PAGERDUTY_TOKEN=             # API key from Account Settings → API Access Keys
PAGERDUTY_USER_EMAIL=        # The email on your PagerDuty account (sandbox email)

# GitHub (optional — without this, GitHub API has 60 req/hr limit. Fine for demo.)
GITHUB_TOKEN=                # https://github.com/settings/tokens (public_repo scope)

# Anthropic (Claude is the agent's brain)
ANTHROPIC_API_KEY=

# Virtuals EconomyOS (the wallet you provisioned at app.virtuals.io/acp/new)
AGENT_PRIVATE_KEY=           # 0x-prefixed private key of the EconomyOS-provisioned wallet
VIRTUALS_BUILDER_CODE=       # bc-... (optional, just shown in logs)
RPC_URL=https://mainnet.base.org

# Demo recipient — used when GitHub username doesn't match WALLET_MAP in server.ts
DEMO_FALLBACK_RECIPIENT=     # any 0x address you control as a second wallet

# Server
PORT=3000
